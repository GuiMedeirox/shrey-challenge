# ==========================================
# Development
# ==========================================

# API
# DB_PATH=./data/contacts.sqlite
# CORS_ORIGIN=                  # leave empty to allow all (dev only)

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ==========================================
# Production (Render + Vercel)
# ==========================================

# API (Render)
# NODE_ENV=production
# PORT=10000
# HOST=0.0.0.0
# LOG_LEVEL=info
# CORS_ORIGIN=https://your-app.vercel.app

# Web (Vercel)
# NEXT_PUBLIC_API_URL=https://contacts-api-xxxxx.onrender.com
